# Supabase 프로젝트 생성 후 Project Settings에서 확인해서 채우기.
# 실제 값이 담긴 .env는 절대 커밋하지 말 것 (.gitignore에 이미 등록됨).

# Project Settings > Database > Connection pooling (Transaction mode, 포트 6543)
DATABASE_URL=postgresql://postgres.xxxx:[password]@aws-0-xxxx.pooler.supabase.com:6543/postgres

# Project Settings > API
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=xxxx

# Storage 탭에서 생성한 버킷 이름
SUPABASE_STORAGE_BUCKET=uploads
